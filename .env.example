# === TIDAL ===
TIDAL_USERNAME=               # email аккаунта Tidal с подпиской (Individual)
TIDAL_PASSWORD=               # пароль аккаунта Tidal
TIDAL_CLIENT_ID=              # из браузера (DevTools) — смотри worker/docs/tidal-api-research.md
TIDAL_CLIENT_SECRET=          # из браузера (DevTools)
TIDAL_SESSION_TOKEN=          # bearer-токен сессии, обновляется автоматически

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=           # токен бота от @BotFather
TELEGRAM_BOT_USERNAME=        # username бота без @
TELEGRAM_ADMIN_IDS=           # через запятую: 123456789,987654321
TELEGRAM_WEBHOOK_SECRET=      # случайная строка для верификации вебхуков

# === JWT / AUTH ===
JWT_SECRET=                   # минимум 64 символа, случайная строка (openssl rand -hex 64)
JWT_REFRESH_SECRET=           # минимум 64 символа, другая строка (openssl rand -hex 64)
SESSION_ENCRYPTION_KEY=       # 32 байта в hex (openssl rand -hex 32)

# === CLOUDFLARE ===
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=         # с правами Workers, D1, KV, R2
CLOUDFLARE_KV_NAMESPACE_ID=2f2ca120b5104617a262332524b27190
CLOUDFLARE_D1_DATABASE_ID=af567808-4d71-4248-89f0-4681371dc771
CLOUDFLARE_R2_BUCKET_NAME=bratanmusic-tracks

# === GITHUB ===
GITHUB_TOKEN=                 # с правами repo, actions, pages
GITHUB_REPO=BRATAN-CORP/bratan-music

# === APP ===
APP_URL=https://bratan-corp.github.io/bratan-music
API_URL=https://api.bratan-corp.workers.dev
ENVIRONMENT=development       # development | production
VITE_BASE_PATH=/bratan-music  # важно для GitHub Pages subdirectory
VITE_BOT_USERNAME=bratan_music_bot
